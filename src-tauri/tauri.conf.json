{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Token Anxiety Dashboard",
  "version": "1.1.0",
  "identifier": "app.token-anxiety.dashboard",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Token Anxiety Dashboard",
        "width": 1180,
        "height": 820,
        "minWidth": 900,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
